CONFIG_IDF_TARGET="esp32p4"
CONFIG_BSP_TARGET_TANMATSU=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partition_tables/16M.csv"
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_TRANSPORT_UART=n
# BLE Security Manager: LE Secure Connections + Passkey Display Entry.
# Tanmatsu shows a 6-digit code on the screen; the iPhone MeshCore app
# prompts the user to type it. LTKs are bonded so the second pairing
# is silent. See VIEW_BLE_PAIR for the display side.
CONFIG_BT_NIMBLE_SM_SC=y
CONFIG_BT_NIMBLE_SM_LEGACY=n
CONFIG_BT_NIMBLE_NVS_PERSIST=y
# Companion opcode dispatch runs inline on the NimBLE host task, and some
# handlers (e.g. contact enumeration) have large stack frames. The IDF default
# (~4 KB) overflowed on GET_CONTACTS; give it headroom so companion handlers
# can't blow the host stack.
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=8192
CONFIG_ESP_WIFI_IRAM_OPT=y
CONFIG_ESP_WIFI_RX_IRAM_OPT=y
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=16
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=17
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=18
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=19
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=20
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=21
CONFIG_ESP_HOSTED_SDIO_RESET_SLAVE_USING_CALLBACK=y
CONFIG_ESP_HOSTED_SLAVE_RESET_ONLY_IF_NECESSARY=y
CONFIG_ESP_HOSTED_HOST_RESTART_NO_COMMUNICATION_WITH_SLAVE=n
CONFIG_ESP_HOSTED_ENABLE_BT_NIMBLE=y
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y
CONFIG_CUSTOM_CA_TANMATSU_APPS=y
CONFIG_CUSTOM_CA_TANMATSU_OTA=y
CONFIG_LCD_DSI_ISR_IRAM_SAFE=y
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=65536
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y
CONFIG_FATFS_VOLUME_COUNT=3
CONFIG_FATFS_VFS_FSTAT_BLKSIZE=8192
CONFIG_FATFS_USE_FASTSEEK=y
CONFIG_FATFS_FAST_SEEK_BUFFER_SIZE=64
CONFIG_FATFS_ALLOC_PREFER_EXTRAM=n
CONFIG_SPI_FLASH_SUPPORT_WINBOND_CHIP=y
CONFIG_USB_HOST_HUBS_SUPPORTED=y
CONFIG_BOOTLOADER_REGION_PROTECTION_ENABLE=n
# ── LVGL 9 (UI migration) ────────────────────────────────────────────────────
# 16-bit colour matches the ST7701S panel (565RGB, little-endian) so the LVGL
# draw buffer blits 1:1 via bsp_display_blit (no per-pixel format conversion).
CONFIG_LV_COLOR_DEPTH_16=y
# Use the C library allocator (ESP heap, PSRAM-capable) rather than LVGL's
# builtin pool — avoids sizing a fixed pool and matches the image-decode path.
CONFIG_LV_USE_CLIB_MALLOC=y
CONFIG_LV_USE_CLIB_STRING=y
CONFIG_LV_USE_CLIB_SPRINTF=y
# Montserrat sizes the UI uses (TXT_TINY 13->14, SMALL 16, BODY 20, TAB 22,
# TITLE 24). 14 is on by default; enable the rest.
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_22=y
CONFIG_LV_FONT_MONTSERRAT_24=y
# Keep the image bulk out of the binary: no demos, examples, or file-system
# image decoders during the core migration.
CONFIG_LV_BUILD_EXAMPLES=n
CONFIG_LV_USE_DEMO_WIDGETS=n
CONFIG_LV_USE_LOG=n
# Trim the binary to fit the 2 MB app partition. The views are built from
# obj/label/line/arc/image/canvas only; every other widget + heavy optional
# subsystem is dead weight here. Re-enable a widget if a later view needs it.
# Canvas (+ its lv_image/lv_label deps) backs the Map view's tile raster.
CONFIG_LV_USE_CANVAS=y
CONFIG_LV_USE_IMAGE=y
CONFIG_LV_USE_LABEL=y
CONFIG_LV_USE_ANIMIMG=n
CONFIG_LV_USE_BAR=n
CONFIG_LV_USE_BUTTON=n
CONFIG_LV_USE_BUTTONMATRIX=n
CONFIG_LV_USE_CALENDAR=n
CONFIG_LV_USE_CHART=n
CONFIG_LV_USE_CHECKBOX=n
CONFIG_LV_USE_DROPDOWN=n
CONFIG_LV_USE_IMAGEBUTTON=n
CONFIG_LV_USE_KEYBOARD=n
CONFIG_LV_USE_LED=n
CONFIG_LV_USE_LIST=n
CONFIG_LV_USE_MENU=n
CONFIG_LV_USE_MSGBOX=n
CONFIG_LV_USE_ROLLER=n
CONFIG_LV_USE_SCALE=n
CONFIG_LV_USE_SLIDER=n
CONFIG_LV_USE_SPAN=n
CONFIG_LV_USE_SPINBOX=n
CONFIG_LV_USE_SPINNER=n
CONFIG_LV_USE_SWITCH=n
CONFIG_LV_USE_TEXTAREA=n
CONFIG_LV_USE_TABLE=n
CONFIG_LV_USE_TABVIEW=n
CONFIG_LV_USE_TILEVIEW=n
CONFIG_LV_USE_WIN=n
CONFIG_LV_USE_SYSMON=n
CONFIG_LV_USE_OBSERVER=n
CONFIG_LV_USE_SNAPSHOT=n
CONFIG_LV_USE_VECTOR_GRAPHIC=n
CONFIG_LV_USE_FREETYPE=n
CONFIG_LV_USE_THORVG=n
CONFIG_LV_USE_MONKEY=n
CONFIG_LV_USE_GRIDNAV=n
CONFIG_LV_USE_FRAGMENT=n
CONFIG_LV_USE_IME_PINYIN=n
CONFIG_LV_USE_FILE_EXPLORER=n
# Reclaim app-partition headroom for the chat views (inline emoji pulls in the
# lv_image transform path). The views position everything absolutely with
# explicit per-object styles, so the theme engine and the flex/grid layout
# engines are dead weight; the fonts are uncompressed bitmaps, so the
# compressed-font decoder is unused too. Montserrat 14/16/20/22/24 stay enabled
# (14 referenced explicitly now that the default theme no longer pins it).
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_USE_THEME_DEFAULT=n
CONFIG_LV_USE_THEME_SIMPLE=n
CONFIG_LV_USE_THEME_MONO=n
CONFIG_LV_USE_FLEX=n
CONFIG_LV_USE_GRID=n
CONFIG_LV_USE_FONT_COMPRESSED=n
CONFIG_LV_FONT_FMT_TXT_LARGE=n
